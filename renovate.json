{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboard": true,
  "rebaseWhen": "never",
  "schedule": ["after 8pm on Friday"],
  "prHourlyLimit": 10,
  "prConcurrentLimit": 10,
  "labels": ["renovate"],
  "rangeStrategy": "bump",
  "separateMajorMinor": true,
  "packageRules": [
    {
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["renovate", "major-update"],
      "addLabels": ["needs-review"]
    },
    {
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "groupName": "型定義パッケージ",
      "matchPackageNames": ["@types/**"],
      "automerge": true
    },
    {
      "matchUpdateTypes": ["minor", "patch"],
      "matchDepTypes": ["dependencies"],
      "groupName": "本番環境依存関係（minor/patch）",
      "groupSlug": "production-dependencies",
      "automerge": true
    },
    {
      "matchUpdateTypes": ["minor", "patch"],
      "matchDepTypes": ["devDependencies"],
      "groupName": "開発環境依存関係（minor/patch）",
      "groupSlug": "dev-dependencies",
      "automerge": true
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions",
      "labels": ["renovate", "github-actions"],
      "automerge": true
    },
    {
      "matchPackageNames": ["next", "react", "react-dom"],
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "groupName": "コアフレームワーク major アップデート",
      "labels": ["renovate", "major-update", "needs-review"]
    }
  ],
  "npm": {
    "enabled": true
  },
  "github-actions": {
    "enabled": true
  }
}
