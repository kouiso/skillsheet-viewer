git fetch origin main develop 2>/dev/null || true

if git rev-parse --verify origin/main >/dev/null 2>&1; then
  if [[ $(git log HEAD..origin/main --oneline) ]]; then
    echo ; echo 🚨🚨🚨 Merge the latest main branch before pushing 🚨🚨🚨 ; echo
    exit 1
  fi
fi

if git rev-parse --verify origin/develop >/dev/null 2>&1; then
  if [[ $(git log HEAD..origin/develop --oneline) ]]; then
    echo ; echo 🚨🚨🚨 Merge the latest develop branch before pushing 🚨🚨🚨 ; echo
    exit 1
  fi
fi
