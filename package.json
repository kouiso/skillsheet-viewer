{
  "name": "skillsheet-viewer",
  "version": "1.0.0",
  "private": true,
  "description": "Engineer Skill Sheet Viewer - Display engineer skill sheets",
  "author": "KosukeIsogai",
  "license": "UNLICENSED",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "22.x"
  },
  "volta": {
    "node": "22.21.1"
  },
  "scripts": {
    "dev": "pnpm --filter @skillsheet/web dev",
    "build": "pnpm --filter @skillsheet/web build",
    "start": "pnpm --filter @skillsheet/web start",
    "lint": "biome check .",
    "format": "biome format --write .",
    "type-check": "pnpm -r type-check",
    "test": "pnpm -r --if-present test",
    "db:generate": "pnpm --filter @skillsheet/db db:generate",
    "db:migrate": "pnpm --filter @skillsheet/db db:migrate"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
