{
  "name": "horsemanager-console",
  "version": "1.0.0",
  "private": true,
  "description": "HM Developer Console (CS Tool)",
  "author": "KosukeIsogai",
  "license": "UNLICENSED",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "start": "next start",
    "dev": "run-s dev:serve",
    "dev:serve": "next dev",
    "dev:debug": "NODE_OPTIONS='--inspect' next dev",
    "build": "next build",
    "postbuild": "next-sitemap",
    "compile": "run-s compile:*",
    "compile:aspida": "rm -rf ./src/lib/aspida && npx openapi2aspida -c aspida.config.cjs",
    "compile:orval": "npx orval",
    "fix": "run-p fix:*",
    "fix:eslint": "eslint . --ext .ts,.tsx --fix",
    "fix:prettier": "prettier .  --write",
    "fix:type-check": "tsc --noEmit",
    "lint": "run-p lint:*",
    "lint:eslint": "eslint . --ext .ts,.tsx",
    "lint:prettier": "prettier . --check",
    "lint:type": "tsc --noEmit",
    "prepare": "husky install",
    "license-check": "license-checker --summary",
    "firebase": "firebase",
    "firebase:emulate": "firebase emulators:start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "lint-staged": {
    "config": "lint-staged.config.js"
  },
  "dependencies": {
    "@aspida/axios": "^1.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@hookform/resolvers": "^5.2.2",
    "@mui/icons-material": "^7.3.5",
    "@mui/material": "^7.3.5",
    "@mui/system": "^7.3.5",
    "@prisma/client": "^6.19.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.90.7",
    "@tanstack/react-query-devtools": "^5.51.16",
    "@trpc/client": "^11.7.1",
    "@trpc/next": "^11.7.1",
    "@trpc/react-query": "^11.7.1",
    "@trpc/server": "^11.7.1",
    "aspida": "^1.14.0",
    "axios": "^1.7.2",
    "bcryptjs": "^3.0.3",
    "classnames": "^2.5.1",
    "next": "^16.0.1",
    "next-auth": "^4.24.13",
    "orval": "^7.16.0",
    "react": "^19.2.0",
    "react-cookie": "^8.0.1",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.66.0",
    "react-hot-toast": "^2.4.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.9.5",
    "react-toastify": "^11.0.3",
    "react-use": "^17.5.1",
    "rehype-pretty-code": "^0.14.1",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "superjson": "^2.2.5",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.56.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/micromatch": "^4.0.10",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.46.3",
    "@typescript-eslint/parser": "^8.46.3",
    "@vitejs/plugin-react-swc": "^3.7.0",
    "@vitest/coverage-v8": "^3.0.9",
    "cspell": "^8.13.0",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsx-a11y": "^6.9.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.9",
    "eslint-plugin-security": "^3",
    "eslint-plugin-sonarjs": "^3.0.5",
    "eslint-plugin-unicorn": "^62.0.0",
    "eslint-plugin-unused-imports": "^4.3.0",
    "husky": "^9.1.7",
    "jsdom": "^27.0.1",
    "license-checker": "^25.0.1",
    "lint-staged": "^16.2.6",
    "micromatch": "^4.0.7",
    "next-sitemap": "^4.2.3",
    "npm-run-all": "^4.1.5",
    "openapi2aspida": "^0.24.0",
    "prettier": "^3.3.3",
    "prisma": "^6.19.0",
    "prisma-docs-generator": "^0.8.0",
    "rollup-plugin-visualizer": "^6.0.5",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vitest": "^3.0.9"
  }
}
