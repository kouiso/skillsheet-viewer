# Environment configuration for Vite
# Copy this file to .env.local and fill in your values
# Note: All environment variables for Vite must be prefixed with VITE_

# Viewer authentication code
VITE_VIEWER_CODE=your_auth_code_here

# GitHub API credentials for skill sheet storage
VITE_GITHUB_TOKEN=your_github_token_here
VITE_GITHUB_OWNER=your_github_username
VITE_GITHUB_REPO=your_repo_name
VITE_GITHUB_FILE_PATH=skillsheet.md
VITE_GITHUB_BRANCH=main
