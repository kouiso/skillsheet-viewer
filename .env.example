NODE_ENV=development

# Docker Compose ports
_DOCKER_COMPOSE_HOST_PORT_FRONTEND=13020
_DOCKER_COMPOSE_HOST_PORT_FRONTEND_DEBUG=19229

# Database
DB_USER=user
DB_PASSWORD=user
DB_HOST=localhost
DB_PORT=55432
DB_DATABASE=app
DATABASE_URL="postgresql://user:user@localhost:55432/app"

# NextAuth.js
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-change-this-in-production

# Seed data (for development/testing)
_DEVELOPER_USERNAME=admin
_DEVELOPER_PASSWORD=admin123
_DEVELOPER_VIEWER_CODE=view123
