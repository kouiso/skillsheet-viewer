{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120,
    "lineEnding": "lf"
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all",
      "semicolons": "always",
      "bracketSpacing": true,
      "jsxQuoteStyle": "double"
    }
  },
  "css": {
    "linter": { "enabled": false },
    "formatter": { "enabled": false }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "suspicious": {
        "noExplicitAny": "warn",
        "noArrayIndexKey": "warn"
      },
      "style": {
        "noNonNullAssertion": "warn"
      },
      "performance": {
        "noImgElement": "warn"
      },
      "a11y": {
        "useSemanticElements": "warn",
        "noNoninteractiveElementToInteractiveRole": "warn"
      }
    }
  },
  "files": {
    "includes": ["**", "!**/node_modules", "!**/.next", "!**/dist", "!**/.turbo", "!pnpm-lock.yaml", "!**/*.css"]
  }
}
